                                        <select class="form-select" id="materialTaxType">
                                            <option value="inclusive">Inclusive (Price includes tax)</option>
                                            <option value="exclusive" selected>Exclusive (Tax added on price)</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <label class="form-label">GST Rate %</label>
                                        <select class="form-select" id="materialGSTRate">
                                            <option value="0">0% (Exempted)</option>
                                            <option value="5">5%</option>
                                            <option value="12">12%</option>
                                            <option value="18" selected>18%</option>
                                            <option value="28">28%</option>
                                        </select>
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label">Tax Account</label>
                                        <input type="text" class="form-control" id="materialTaxAccount"
                                            placeholder="Leave blank for default">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Remarks -->
                        <div class="mb-3">
