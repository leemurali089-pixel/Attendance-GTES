    // Format time from 24h to 12h AM/PM format
    formatTimeDisplay(time24) {
        if (!time24) return '-';
        const [hour, minute] = time24.split(':').map(Number);
        let displayHour = hour;
        let period = 'AM';

        if (hour === 0) {
            displayHour = 12;
            period = 'AM';
        } else if (hour === 12) {
            displayHour = 12;
            period = 'PM';
        } else if (hour > 12) {
