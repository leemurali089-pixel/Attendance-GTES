        if (!tbody) return;

        const rows = tbody.querySelectorAll('tr');
        const showOnlyPending = toggle.checked;

        rows.forEach(row => {
            const remaining = parseFloat(row.getAttribute('data-remaining') || 0);
            if (showOnlyPending) {
                // Show only rows with remaining > 0
                row.style.display = remaining > 0 ? '' : 'none';
