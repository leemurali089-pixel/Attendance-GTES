                                        <div class="mt-auto pt-3 border-top border-secondary">
                                            <div class="row g-2">
                                                <div class="col-6">
                                                     <button class="btn btn-outline-danger w-100 btn-sm" onclick="TasksUI.deleteTask('${task.id}', true)">
