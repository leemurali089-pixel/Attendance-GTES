    },

    showOtPayBreakdown(employeeName, standardHours, standardRate, standardPay, hHours, hRate, hPay, totalPay) {
        this._ensureOtBreakdownModal();

        const modal = new bootstrap.Modal(document.getElementById('otBreakdownModal'));
