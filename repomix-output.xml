                                            </label>
                                        </div>
                                        <input type="number" class="form-control form-control-sm" id="materialCount"
                                            placeholder="0" step="1" disabled>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-secondary">
