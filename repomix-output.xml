                            <small class="text-muted">Internal notes (won't be displayed)</small>
                        </div>

                        <!-- Additional Columns -->
                        <div class="card bg-secondary mb-3">
                            <div class="card-header">
                                <strong>Additional Tracking Columns</strong>
                                <small class="text-muted ms-2">Enable optional fields for batch tracking</small>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <!-- Batch -->
                                    <div class="col-md-6 mb-3">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" id="enableBatchField">
                                            <label class="form-check-label" for="enableBatchField">
                                                <strong>Batch Number</strong>
                                            </label>
                                        </div>
                                        <input type="text" class="form-control form-control-sm" id="materialBatch"
                                            placeholder="e.g., BATCH-2025-001" disabled>
                                    </div>

                                    <!-- Manufacturing Date -->
                                    <div class="col-md-6 mb-3">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" id="enableMfgDateField">
                                            <label class="form-check-label" for="enableMfgDateField">
                                                <strong>Manufacturing Date</strong>
                                            </label>
                                        </div>
                                        <input type="date" class="form-control form-control-sm" id="materialMfgDate"
                                            disabled>
                                    </div>

                                    <!-- Expiry Date -->
                                    <div class="col-md-6 mb-3">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" id="enableExpDateField">
                                            <label class="form-check-label" for="enableExpDateField">
                                                <strong>Expiry Date</strong>
                                            </label>
                                        </div>
                                        <input type="date" class="form-control form-control-sm" id="materialExpDate"
                                            disabled>
                                    </div>

                                    <!-- Weight -->
                                    <div class="col-md-6 mb-3">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" id="enableWeightField">
                                            <label class="form-check-label" for="enableWeightField">
                                                <strong>Weight (kg)</strong>
                                            </label>
                                        </div>
                                        <input type="number" class="form-control form-control-sm" id="materialWeight"
                                            placeholder="0.00" step="0.01" disabled>
                                    </div>

                                    <!-- Height -->
                                    <div class="col-md-6 mb-3">
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" id="enableHeightField">
