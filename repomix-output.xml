                date: inv.date
            });
        });

        // Add recent payments
        vouchers.slice(-10).forEach(v => {
            activities.push({
                type: 'payment',
                icon: 'bi-cash',
                color: 'info',
                title: `Payment Received`,
                description: `${v.customerName} - ₹${v.amount}`,
                date: v.date
            });
        });

        // Add recent expenses
        expenses.slice(-10).forEach(exp => {
