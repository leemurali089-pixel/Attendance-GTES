                                    <option value="Pipes & Fittings">
                                    <option value="Safety Equipment">
                                    <option value="Electronics">
                                    <option value="Hardware">
                                    <option value="Consumables">
                                </datalist>
                            </div>
                        </div>

                        <!-- Subcategory & Brand -->
                        <div class="row mb-3">
                            <div class="col-md-6">
