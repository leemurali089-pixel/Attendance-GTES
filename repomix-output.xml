    <!-- Error Handling -->
    <script>
        window.addEventListener('error', function (e) {
            console.error('Error:', e.message, 'at', e.filename, ':', e.lineno);
            // Only show alert for critical errors, not script errors from other origins
            if (e.filename && !e.filename.includes('://') && e.message !== 'Script error.') {
                console.error('Application error detected');
            }
        });

        // Check if all scripts loaded
        window.addEventListener('load', function () {
            if (typeof DataManager === 'undefined' || typeof App === 'undefined') {
                alert('Some required scripts failed to load. Please check:\n1. All files are in the correct folders\n2. No file names are misspelled\n3. You have internet connection for Bootstrap and icons');
            }
        });

        document.addEventListener('DOMContentLoaded', function () {
            const navImportInput = document.getElementById('navImportFile');
            if (navImportInput) {
                navImportInput.addEventListener('change', function (event) {
                    const file = event.target.files[0];
                    if (file) {
                        AdminModule.importBackup(file);
                        event.target.value = '';
                    }
                });
            }

            const bkImportInput = document.getElementById('bkImportFile');
            if (bkImportInput) {
                bkImportInput.addEventListener('change', async function (event) {
                    const file = event.target.files[0];
                    if (file) {
                        try {
                            App.showNotification('Syncing with Book Keeper...', 'info');
                            const stats = await BookKeeperImport.runFullImport(file);
                            const summary = BookKeeperImport.getSummary(stats);
                            await BookKeeperImport.cleanupImportedData();

                            // Show detailed report modal
                            const modalBody = document.getElementById('syncReportBody');
                            if (modalBody) {
                                let html = `
                                    <div class="text-center mb-4">
                                        <div class="display-1 text-success mb-2"><i class="bi bi-check-circle"></i></div>
                                        <h4>Sync Completed!</h4>
                                        <p class="text-muted">Process took ${summary.duration.toFixed(2)}s</p>
                                    </div>
                                    <div class="list-group mb-4">
                                `;

                                summary.sections.forEach(s => {
                                    if (s.status === 'success') {
                                        html += `
                                            <div class="list-group-item d-flex justify-content-between align-items-center bg-dark text-white border-secondary">
                                                <div>
                                                    <i class="bi bi-check-circle-fill text-success me-2"></i> ${s.name}
                                                </div>
                                                <span class="badge bg-primary rounded-pill">${s.imported || 0}</span>
                                            </div>
                                        `;
                                    } else {
                                        html += `
                                            <div class="list-group-item list-group-item-danger d-flex justify-content-between align-items-center">
                                                <div>
                                                    <i class="bi bi-exclamation-triangle-fill me-2"></i> ${s.name}
                                                </div>
                                                <small>${s.message}</small>
                                            </div>
                                        `;
                                    }
                                });

                                html += `</div>`;

                                if (stats.errors && stats.errors.length > 0) {
                                    html += `
                                        <div class="alert alert-warning small">
                                            <h6 class="alert-heading"><i class="bi bi-exclamation-circle"></i> Warnings/Errors:</h6>
                                            <ul class="mb-0 ps-3">
                                                ${stats.errors.map(e => `<li>${e.section}: ${e.error}</li>`).join('')}
                                            </ul>
                                        </div>
                                    `;
                                }

                                // DEBUG INFO
                                if (summary.foundTables && summary.foundTables.length > 0) {
                                    html += `
                                        <div class="accordion" id="debugAccordion">
                                            <div class="accordion-item bg-dark border-secondary">
                                                <h2 class="accordion-header" id="headingDebug">
                                                    <button class="accordion-button collapsed bg-dark text-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDebug" aria-expanded="false" aria-controls="collapseDebug">
                                                        <i class="bi bi-bug me-2"></i> Debug Info (Tables Found)
                                                    </button>
                                                </h2>
                                                <div id="collapseDebug" class="accordion-collapse collapse" aria-labelledby="headingDebug" data-bs-parent="#debugAccordion">
                                                    <div class="accordion-body small text-muted font-monospace" style="max-height: 200px; overflow-y: auto;">
                                                        <p class="mb-1"><strong>Found Tables:</strong> ${summary.foundTables.join(', ')}</p>
                                                        ${stats.debugColumns ? `
                                                            <hr class="my-1 border-secondary">
                                                            <p class="mb-1 text-warning"><strong>📊 Use these names for support:</strong></p>
                                                            ${Object.entries(stats.debugColumns).map(([table, cols]) => `
                                                                <div class="mb-2">
                                                                    <span class="text-info">${table}:</span> 
                                                                    <span class="text-white small">
                                                                        ${Array.isArray(cols)
                                            ? cols.join(', ')
                                            : typeof cols === 'object'
                                                ? JSON.stringify(cols, null, 2).replace(/\n/g, '<br>').replace(/ /g, '&nbsp;')
                                                : cols}
                                                                    </span>
                                                                </div>
                                                            `).join('')}
                                                        ` : ''}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                     `;
                                }

                                modalBody.innerHTML = html;
                                const modal = new bootstrap.Modal(document.getElementById('syncReportModal'));
                                modal.show();
                            } else {
                                App.showNotification(`Sync Complete! ${summary.totalImported} items updated.`, 'success');
                            }

                            // Refresh current view if needed
                            if (window.AccountingUI && typeof window.AccountingUI.renderDashboard === 'function') {
                                window.AccountingUI.renderDashboard();
                            }
                            // Also refresh inventory/delivery views if open
                            if (window.DeliveryUI && document.getElementById('inventoryView') && !document.getElementById('inventoryView').classList.contains('d-none')) {
                                DeliveryUI.loadInventory();
                            }

                        } catch (e) {
                            console.error('BookKeeper Sync Error:', e);
                            App.showNotification('Sync Failed: ' + e.message, 'error');
                        }
                        event.target.value = '';
                    }
                });
            }
        });
    </script>
    
