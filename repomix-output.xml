                                        <i class="bi bi-plus-circle"></i>
                                    </button>
                                </div>
                                <datalist id="brandList">
                                    <option value="BOC">
                                    <option value="Linde">
                                    <option value="Air Liquide">
                                    <option value="Generic">
                                </datalist>
                            </div>
                        </div>

                        <!-- Item Name & HSN -->
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label class="form-label">Item Name *</label>
                                <input type="text" class="form-control" id="materialName" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">HSN Code</label>
                                <input type="text" class="form-control" id="materialHSN" maxlength="8">
                                <small class="text-muted">For GST</small>
                            </div>
                        </div>

