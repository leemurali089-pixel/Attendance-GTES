    // NEW: Return to Landing Page
    showLandingPage() {
        this.currentView = 'landing';
        const landingView = document.getElementById('landingView');
        const nav = document.querySelector('.navbar');

        // Hide Navbar
        if (nav) nav.style.display = 'none';

