                                        `}
                                        
                                        <button class="btn btn-outline-success fw-bold py-2 border-success border-opacity-50" onclick="TasksUI.applyAndShareUpdate('${task.id}')">
                                            <i class="bi bi-whatsapp me-2"></i> Apply and Share update to WhatsApp
