                                                    <button class="btn btn-outline-warning btn-sm flex-grow-1" onclick="TasksUI.postponeTask('${task.id}', 1, 'day')">
                                                        Next Day
                                                    </button>
                                                    <button class="btn btn-warning btn-sm flex-grow-1 fw-bold" onclick="TasksUI.confirmReschedule('${task.id}')">
                                                        Apply Custom
                                                    </button>
                                                </div>
