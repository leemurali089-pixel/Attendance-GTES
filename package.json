{
    "name": "attendance-gtes",
    "version": "1.3.9",
    "description": "MJS PrimeLogic - Attendance & Salary Management System",
    "main": "main.js",
    "author": "Murali D",
    "scripts": {
        "start": "node node_modules/electron/cli.js .",
        "start:electron": "electron .",
        "build": "electron-builder",
        "release": "electron-builder --publish=always",
        "release:draft": "electron-builder --publish=onTagOrDraft"
    },
    "productName": "MJS PrimeLogic",
    "build": {
        "appId": "com.mjsprimelogic.app",
        "productName": "MJS PrimeLogic",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/**/*",
            "!.git/**/*",
            "!*.md",
            "!test*.html",
            "!test*.csv",
            "!Data/**/*",
            "!Backups/**/*",
            "!ChallanOutput/**/*",
            "!Salary Payout/**/*",
            "!.agent/**/*"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "MJS PrimeLogic"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "leemurali089-pixel",
                "repo": "Attendance-GTES",
                "releaseType": "release"
            }
        ]
    },
    "devDependencies": {
        "electron": "^39.2.4",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "@googleapis/gmail": "^11.0.0",
        "@googleapis/oauth2": "^2.0.0",
        "electron-updater": "^6.8.3",
        "google-auth-library": "^9.15.0",
        "nodemailer": "^7.0.11"
    }
}
