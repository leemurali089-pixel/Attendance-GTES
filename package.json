{
    "name": "attendance-gtes",
    "version": "1.0.0",
    "description": "MJS PrimeLogic - Attendance & Salary Management System",
    "main": "main.js",
    "author": "Murali D",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "productName": "MJS PrimeLogic",
    "build": {
        "appId": "com.mjsprimelogic.app",
        "productName": "MJS PrimeLogic",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "MJS PrimeLogic"
        }
    },
    "devDependencies": {
        "electron": "^39.2.4",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "nodemailer": "^7.0.11"
    }
}
